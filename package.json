{
  "name": "aintaword2",
  "version": "0.1.0",
  "description": "A collection of browser word games. First game: Ain't a Word — a 60-second spot-the-real-word score attack.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "words": "node scripts/build-words.mjs",
    "daily": "node scripts/build-daily.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:colorpath": "node scripts/verify-colorpath.mjs",
    "e2e": "node scripts/e2e.mjs",
    "e2e:colorpath": "node scripts/e2e-colorpath.mjs",
    "snapshot": "node scripts/snapshot.mjs",
    "test": "npm run verify && npm run verify:colorpath && npm run e2e && npm run e2e:colorpath"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
